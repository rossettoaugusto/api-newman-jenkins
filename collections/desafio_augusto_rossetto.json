                  "",
                  "pm.test(\"Filtro retornou \" + totalProdutos + \" produtos da categoria electronics\", function() { pm.expect(json).to.be.an('array').and.to.have.lengthOf.above(0); });"
                ],
                "type": "text/javascript",
